# Backend adapter: "oms" (live OMS) or "stub" (in-memory demo data)
VITE_RETURNS_BACKEND=stub

# Base URLs (used only when VITE_RETURNS_BACKEND=oms; resolved via @common commonUtil)
VITE_VUE_APP_OMS_API_URL=
VITE_VUE_APP_MAARG_API_URL=
VITE_VUE_APP_DEFAULT_LOG_LEVEL=error

# DEMO ONLY: this Moqui build authenticates via the `api_key` header (Bearer JWT isn't wired).
# @common doesn't capture/send api_key, so paste a UserLoginKey here (the `api_key` field from
# POST /rest/s1/admin/login). The omsAdapter sends it on every call. Refresh when it expires.
VITE_RETURNS_API_KEY=
