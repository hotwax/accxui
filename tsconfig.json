{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./apps/job-manager/src/*"],
      "@common": ["./common/index.ts"],
      "@common/*": ["./common/*"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "apps/**/*.vue", "common/**/*.ts"],
  "exclude": ["node_modules", "**/dist"]
}
